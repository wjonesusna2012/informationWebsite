# Do this because of babel-loader needed for storybook.
SKIP_PREFLIGHT_CHECK=true
# Set HOST to localhost to avoid binding issues
HOST=localhost

# Custom app environment variables (must start with REACT_APP_)
REACT_APP_API_URL=http://localhost:4000
REACT_APP_TRPC_URL=http://localhost:4000/trpc
REACT_APP_ENVIRONMENT=development